{
  "info": {
    "name": "Syrin Remote Config (12_remote_config)",
    "description": "Flow for GET/PATCH /config and config/stream. Run init_and_serve.py first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "agent_id", "value": "my_agent:Agent" }
  ],
  "item": [
    {
      "name": "1. Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health",
        "description": "Optional; confirms server is up."
      }
    },
    {
      "name": "2. GET config (schema + values)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/config",
        "description": "Required before PATCH. Copy agent_id from response into collection variable agent_id."
      }
    },
    {
      "name": "3. PATCH config (apply overrides)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agent_id\": \"{{agent_id}}\",\n  \"version\": 1,\n  \"overrides\": [\n    { \"path\": \"budget.run\", \"value\": 2.0 }\n  ]\n}"
        },
        "url": "{{baseUrl}}/config",
        "description": "Use agent_id from GET /config. Response: accepted, rejected, pending_restart."
      }
    },
    {
      "name": "4. GET config/stream (SSE)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/config/stream",
        "description": "Infinite SSE stream: heartbeat then override events when PATCH is applied. Postman will show first chunk."
      }
    },
    {
      "name": "5. GET budget",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/budget",
        "description": "Current budget state (limit, remaining, spent). 404 if no budget."
      }
    },
    {
      "name": "6. GET describe",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/describe",
        "description": "Agent name, description, tools, budget summary."
      }
    },
    {
      "name": "7. POST chat",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"Say hello in one word\"\n}"
        },
        "url": "{{baseUrl}}/chat",
        "description": "Run agent once. Body: message or input. Response: content, cost, tokens, etc."
      }
    }
  ]
}
